captures/

# Kotlin/Java generated sources
app/src/main/gen/

# Lint output
lint-results*.xml
lint-results*.html

# Test results
app/src/test/
app/src/androidTest/

# OS-specific
Thumbs.db
ehthumbs.db
Desktop.ini
